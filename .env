MSSQL_SERVER=192.168.0.251,1433
MSSQL_USER=sa
MSSQL_PASSWORD=sa@123
MSSQL_DB=face_attendance
MSSQL_DRIVER=ODBC Driver 18 for SQL Server
MSSQL_TRUST_CERT=yes

EMBEDDING_DIM=512

# ── FAISS / HNSW (tuned for 100 employees) ───────────────────────────────────
# Threshold: 0.50 = solid ArcFace match (was 0.60 which is very strict)
# If you get false positives, increase toward 0.60.
# If you get false rejections (real person not recognized), decrease toward 0.45.
FAISS_COSINE_THRESHOLD=0.5

# Multi-anchor: store K diverse embeddings per person in FAISS
# 100 people x 3 anchors = 300 vectors — covers different angles/lighting
MULTI_EMB_COUNT=3

# Frames to capture during enrollment (more = better diversity selection)
ONBOARD_FRAMES=20

# HNSW index parameters (do not change unless scaling to 10,000+ people)
HNSW_M=48
HNSW_EF_SEARCH=128
HNSW_EF_CONSTRUCT=400

# Multi-Camera configuration (Name1:URL1,Name2:URL2)
RTSP_URLS=Exit:rtsp://test:admin123@192.168.1.213:554/stream,Entrance:rtsp://test:admin123@192.168.1.2:554/stream,C3:rtsp://test:admin123@192.168.2.221:554/stream

# Individual camera toggles (true/false)
CAMERAS_ENABLED=Exit:true,Entrance:true,C3:false
EXIT_CAM_KEYWORDS=Exit,OUT,C3
SPEAKER_DEVICE_IDS=Exit:G-5889-6B1B-5AE0,Entrance:,C3:NONE
EXTERNAL_API_ENABLED=True
EXTERNAL_API_URL=ws://192.168.1.10/ws
# Method: POST or WebSocket
# For camera-specific URLs use comma-separated Name:URL
EXTERNAL_API_URLS=C3:ws://192.168.2.10/ws
# Method: POST or WebSocket
EXTERNAL_API_TIMEOUT=10
# DOOR_UNLOCK_MODE options:
#   "API"       -> Calls the REMOTE_DOOR_API_URL (Grapes Online HTTP API)
#   "WEBSOCKET" -> Calls the EXTERNAL_API_URL (Local Hardware WS)
#   "AUTO"      -> Detects based on URL prefixes
DOOR_UNLOCK_MODE=WEBSOCKET

# Remote Door Control (Grapes Online)
# Method: POST
REMOTE_DOOR_API_URL=http://emplog.grapesonline.net/Admin/LockOrUnlockDoorRemotely?BranchId={branch_id}&Status=true&UserId={user_id}
BRANCH_ID=2

# ML Accuracy Boost (User's Fast Settings)
FACE_MIN_SIZE=60
BLUR_THRESHOLD=50.0
# Consensus: 3 of last 6 frames must agree (faster for groups)
CONSENSUS_WINDOW=6
CONSENSUS_THRESHOLD=3
MONITOR_COOLDOWN=30

API_HOST=0.0.0.0
API_PORT=8000

# Authentication
AUTH_USERNAME=admin
AUTH_PASSWORD=1234
STREAMING_DEFAULT_ENABLED=False
# Method: GET
RF_CHECK_API_URL=http://emplog.grapesonline.net/Employee/GetEmployeeDetails?RfID={rf_card}

# Method: POST
LOG_ENTRY_API_URL=http://emplog.grapesonline.net/Employee/LogEmployeeEntry?MacAddress={mac}&EmployeeID={id}&Status=IN

# Method: POST
LOG_EXIT_API_URL=http://emplog.grapesonline.net/Employee/LogEmployeeEntry?MacAddress={mac}&EmployeeID={id}&Status=OUT
DEVICE_MAC_ADDRESS=84:1F:E8:24:A0:5C
TRAY_ICON_ENABLED=False
SPEAKER_API_URL=http://192.168.0.251:3596/api/User/SendTextToSpeaker?DeviceID={device_id}&Message={message}&VoiceOption=Microsoft%20Zira%20Desktop
# Method: POST
SPEAKER_DEVICE_ID=G-5889-6B1B-5AE0

# ── Motion Detection (AI Sleep Mode) ──────────────────────────────────────────
MOTION_DETECTION_ENABLED=False
MOTION_THRESHOLD=5.0
MOTION_SLEEP_TIME=5.0
MONITOR_ENABLED=True
FACE_LABELING_ENABLED=True

# AUDIO_MODE options: 
#   "API" -> Calls the SPEAKER_API_URL (Network Speaker via HTTP POST)
AUDIO_MODE=API
TTS_VOICE_RATE=140
# Enrollment settings for the engine only

# ── PC Automation (Wake-on-LAN ON / Shutdown signal OFF) ──────────────────────
# Set to true to automatically wake/shutdown employee PCs based on their
# face recognition events (requires pc_mac and pc_ip fields per employee).
PC_CONTROL_ENABLED=True
PC_OFFICE_HOURS_START=9
PC_OFFICE_HOURS_END=17
